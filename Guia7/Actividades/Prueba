package Actividad1;

public class Prueba {
    public static void main(String[] args) {
        LinkedBST<Integer> arbol = new LinkedBST<>();

        System.out.println("--- LABORATORIO 07: RECORRIDOS Y EXTREMOS ---");

        try {
            // Inserción inicial para poder probar 
            arbol.insert(400);
            arbol.insert(100);
            arbol.insert(700);
            arbol.insert(50);
            arbol.insert(200);
            arbol.insert(75);

            // 1. PRUEBA DE RECORRIDOS (Actividades 7, 8 y 9)
            System.out.println("\nEjecutando Recorridos:");
            
            // In-Orden: Izquierda - Raíz - Derecha 
            arbol.inOrder();   
            
            // Pre-Orden: Raíz - Izquierda - Derecha 
            arbol.preOrder();  
            
            // Post-Orden: Izquierda - Derecha - Raíz 
            arbol.postOrder(); 

            // 2. MÍNIMO Y MÁXIMO 
            System.out.println("\nValores Extremos del Árbol:");
            // Busca el valor más a la izquierda
            System.out.println("Valor Mínimo: " + arbol.findMin()); 
            // Busca el valor más a la derecha
            System.out.println("Valor Máximo: " + arbol.findMax()); 

        } catch (ItemDuplicated e) {
            System.err.println(e.getMessage());
        } catch (ItemNoFound e) {
            System.err.println(e.getMessage());
        } catch (Exception e) {
            System.err.println("Error: " + e.getMessage());
        }
    }
}
