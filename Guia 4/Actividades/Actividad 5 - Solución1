public class Moda1 {

    // Cuenta frecuencia de un número
    public static int frecuencia(int[] arr, int valor) {
        int count = 0;
        for (int num : arr) {
            if (num == valor) {
                count++;
            }
        }
        return count;
    }

    public static int moda(int[] arr) {
        int maxFrecuencia = 0;
        int moda = arr[0];

        for (int i = 0; i < arr.length; i++) {
            int freq = frecuencia(arr, arr[i]);

            if (freq > maxFrecuencia) {
                maxFrecuencia = freq;
                moda = arr[i];
            }
        }

        return moda;
    }

    public static void main(String[] args) {
        int[] arr = {1, 2, 2, 3, 3, 3, 4};
        System.out.println("Moda: " + moda(arr));
    }
}

