package actividad2;
import Actividad1.ExceptionIsEmpty;

public class TestActividad2 {
    public static void main(String[] args) throws ExceptionIsEmpty {

        Deque<Integer> deque = new DequeLink<>();

        System.out.println("Agregando elementos:");
        deque.addFirst(10);
        deque.addLast(20);
        deque.addFirst(5);
        deque.addLast(30);

        System.out.println("Contenido: " + deque);

        System.out.println("Primero: " + deque.getFirst());
        System.out.println("Último: " + deque.getLast());

        System.out.println("Eliminar primero: " + deque.removeFirst());
        System.out.println("Eliminar último: " + deque.removeLast());

        System.out.println("Contenido final: " + deque);

        System.out.println("¿Está vacío? " + deque.isEmpty());
    }
}
